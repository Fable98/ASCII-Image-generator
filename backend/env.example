# ASCII Stream Backend — environment variables
# Copy to .env and fill in production values

# App
DEBUG=false
LOG_LEVEL=INFO

# Auth — CHANGE THIS in production
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_MINUTES=60

# Session
SESSION_TTL_SECONDS=600
MAX_SESSIONS_PER_IP=10

# Backpressure
DEFAULT_MAX_FPS=15
FRAME_QUEUE_MAXSIZE=2
WORKER_CONCURRENCY=4
MAX_FRAME_BYTES=2097152

# Storage: "local" or "s3"
SNAPSHOT_BACKEND=local
SNAPSHOT_LOCAL_DIR=/tmp/ascii_snapshots

# S3 (only if SNAPSHOT_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1

# Redis (optional)
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
